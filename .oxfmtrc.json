{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [],
	"singleQuote": true,
	"arrowParens": "avoid",
	"singleAttributePerLine": true,
	"htmlWhitespaceSensitivity": "strict",
	"semi": true,
	"jsdoc": true,
	"useTabs": true,
	"sortImports": true,
	"sortTailwindcss": true,
	"printWidth": 100,
	"quoteProperties": "asNeeded",
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"objectWrap": "preserve",
	"endOfLine": "lf"
}
